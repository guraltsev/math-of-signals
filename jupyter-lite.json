{
  "jupyter-lite-schema-version": 0,
  "jupyter-config-data": {
    "defaultKernelName": "python",
    "disabledExtensions": [
      "@jupyterlab/drawio-extension",
      "jupyterlab-kernel-spy",
      "jupyterlab-tour",
      "@jupyterlab/filebrowser-extension:browser",
      "@jupyterlab/launcher-extension:plugin"
    ],
    "litePluginSettings": {
      "@jupyterlite/pyodide-kernel-extension:kernel": {
        "pyodideUrl": "./pyodide/pyodide.js",
        "loadPyodideOptions": {
          "lockFileURL": "./pyodide/pyodide-lock.json",
          "packages": [
            "numpy",
            "pandas",
            "scipy",
            "sympy",
            "ipywidgets",
            "anywidget",
            "plotly"
          ]
        }
      }
    },
    "contentsStorageDrivers": [
      "memoryStorageDriver"
    ],
    "settingsStorageDrivers": [
      "memoryStorageDriver"
    ],
    "enableMemoryStorage": true,
    "workspacesStorageDrivers": [
      "memoryStorageDriver"
    ],
    "settingsOverrides": {
      "@jupyterlab/notebook-extension:tracker": {
        "autoStartDefaultKernel": true
      }
    }
  }
}
